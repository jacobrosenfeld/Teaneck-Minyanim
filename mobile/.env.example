# Copy to .env.local for local development.
# For release builds, provide EXPO_PUBLIC_* analytics vars via
# your EAS environment/secrets (do not commit real keys).
EXPO_PUBLIC_API_URL=http://localhost:8080

# Analytics (disabled by default; enable only after PostHog project setup)
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SESSION_REPLAY_ENABLED=false
