{
  "expo": {
    "name": "Teaneck Minyanim",
    "slug": "teaneck-minyanim",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "teaneckminyanim",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.teaneckminyanim.app",
      "buildNumber": "25",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Teaneck Minyanim uses your location to show nearby shuls and sort by distance.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Teaneck Minyanim uses your location to show nearby shuls and sort by distance.",
        "NSUserTrackingUsageDescription": "We request permission to measure app usage and improve the app experience while respecting your privacy choices.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.teaneckminyanim.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Teaneck Minyanim uses your location to show nearby shuls and sort by distance."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#275ed8",
          "sounds": []
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "We request permission to measure app usage and improve the app experience while respecting your privacy choices."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "95dba4f3-e045-472d-b34e-05f45ca7add8"
      }
    },
    "owner": "jacobrosenfeld",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/95dba4f3-e045-472d-b34e-05f45ca7add8"
    }
  }
}
